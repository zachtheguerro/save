local httpService = game:GetService('HttpService')

local SaveManager = {} do
    SaveManager.Folder = 'Mana'
    SaveManager.Ignore = {}
    
    -- Helper to get all .json files in the settings folder
    function SaveManager:RefreshConfigList()
        self:BuildFolderTree()
        local files = listfiles(self.Folder .. '/settings')
        local configs = {}
        for _, file in next, files do
            if file:sub(-5) == ".json" then
                -- Extract just the filename without path or extension
                local name = file:match("([^/%\\]+)%.json$")
                table.insert(configs, name)
            end
        end
        return configs
    end

    function SaveManager:BuildFolderTree()
        local paths = { self.Folder, self.Folder .. '/settings' }
        for _, path in next, paths do
            if not isfolder(path) then makefolder(path) end
        end
    end

    function SaveManager:Save(name)
        local fullPath = self.Folder .. '/settings/' .. name .. '.json'
        local data = { objects = {} }

        for flag, value in next, library.flags do
            if self.Ignore[flag] or flag == "cfgname" or flag == "selectedcfg" then continue end
            
            local dataType = "Toggle"
            if typeof(value) == "Color3" then dataType = "ColorPicker"
            elseif typeof(value) == "number" then dataType = "Slider"
            elseif typeof(value) == "EnumItem" then dataType = "Keybind"
            elseif typeof(value) == "table" then dataType = "Dropdown" end

            local savedValue = value
            if dataType == "ColorPicker" then savedValue = value:ToHex()
            elseif dataType == "Keybind" then savedValue = tostring(value) end

            table.insert(data.objects, { type = dataType, idx = flag, value = savedValue })
        end

        local success, encoded = pcall(httpService.JSONEncode, httpService, data)
        if success then
            writefile(fullPath, encoded)
            return true
        end
    end

    function SaveManager:Load(name)
        local file = self.Folder .. '/settings/' .. name .. '.json'
        if not isfile(file) then return false end

        local success, decoded = pcall(httpService.JSONDecode, httpService, readfile(file))
        if not success then return false end

        for _, data in next, decoded.objects do
            local finalValue = data.value
            if data.type == "ColorPicker" then
                finalValue = Color3.fromHex(data.value)
            elseif data.type == "Keybind" then
                local type, name = data.value:match("Enum%.(%w+)%.(.+)")
                finalValue = Enum[type][name]
            end

            -- Find the actual UI object in library.objects to call :Set()
            for _, obj in next, library.objects do
                if typeof(obj) == "table" and obj.flag == data.idx and obj.Set then
                    obj:Set(finalValue)
                    break
                end
            end
        end
        return true
    end
end

return SaveManager
