function library.createkeybind(parent, cfg)
	local default = cfg.default or cfg.Default or nil;
	local mode = cfg.mode or cfg.Mode or "Toggle";
	local blacklist = cfg.blacklist or cfg.Blacklist or {Enum.UserInputType.MouseMovement, Enum.KeyCode.Backspace} or cfg.blacklist and {Enum.UserInputType.MouseMovement, Enum.KeyCode.Backspace} or cfg.Blacklist and {Enum.UserInputType.MouseMovement, Enum.KeyCode.Backspace};
	local flag = cfg.flag or cfg.Flag or library:nextflag();
	local callback = cfg.callback or cfg.Callback or function() end;
	local sync = cfg.sync or cfg.Sync or false;
	local state = cfg.state or cfg.State or false;
	local list = cfg.list or cfg.List or false;
	local key_mode = mode;
	local Keybindframe;
	local Keybindtextleft;
	local Keybindtextright;
	local keybind = {
		type = "keybind",
		key = default,
		mode = key_mode,
		value = state,
		cfg = cfg,
		sync = sync
	};

	if list then
		Keybindframe = library:Create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0);
			BackgroundTransparency = 1;
			Size = UDim2.new(1, 0, 0, 18);
			Visible = true;
			Parent = KeybindContainerContent;
			ZIndex = 50;
		});

		Keybindtextleft = library:Create("TextLabel", {
			FontFace = library.font;
			TextColor3 = state and library.accent or library.textcolor;
			TextSize = 12;
			Text = cfg.parentname;-- .. " (" .. key_mode .. ")"; 
			TextXAlignment = Enum.TextXAlignment.Left;
			TextYAlignment = Enum.TextYAlignment.Bottom;
			BackgroundTransparency = 1;
			Position = UDim2.new(0.02, 0, 0, 0);
			Size = UDim2.new(0.75, 0, 0.75, 0);
			Visible = true;
			Parent = Keybindframe;
			ZIndex = 50;
		});

		Keybindtextleft:SetAttribute("IsAccent", "TextColor3")
		Keybindtextleft:SetAttribute("Selected", state)

		Keybindtextright = library:Create("TextLabel", {
			FontFace = library.font;
			TextColor3 = state and library.accent or library.textcolor;
			TextSize = 12;
			Text = "[" .. (default and keys[default] or "[None]") .. "]";
			TextXAlignment = Enum.TextXAlignment.Right;
			TextYAlignment = Enum.TextYAlignment.Bottom;
			BackgroundTransparency = 1;
			Position = UDim2.new(0.73, 0, 0, 0);
			Size = UDim2.new(0.23, 0, 0.75, 0);
			Visible = true;
			Parent = Keybindframe;
			ZIndex = 50;
		});

		Keybindtextright:SetAttribute("IsAccent", "TextColor3")
		Keybindtextright:SetAttribute("Selected", state)

		library.binds[Keybindframe] = Keybindframe;
	end

	function keybind:set(newState, skipCallback)
		if state == newState then return end 
		state = newState
		library.flags[flag] = newState
		keybind.value = newState

		if list and Keybindframe then
			if state then
				Keybindtextleft.TextColor3 = library.accent
