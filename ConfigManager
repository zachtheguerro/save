local HttpService = game:GetService("HttpService")

local ConfigManager = {}
ConfigManager.Items = {}
ConfigManager.Folder = ""

function ConfigManager:SetFolder(folder)
    self.Folder = folder
    self.AutoloadFile = folder .. "/autoload.txt"
end

function ConfigManager:Register(flag, item)
    if not flag or flag == "" then return end
    self.Items[flag] = item
end

function ConfigManager:SerializeValue(item)
    if item.type == "toggle" then
        local result = {
            type = "toggle",
            value = item.value
        }

        if item.Keybind then
            result.keybind = {
                flag = item.Keybind.cfg.flag,
                default = item.Keybind.key and tostring(item.Keybind.key) or nil,
                mode = item.Keybind.mode,
                state = item.Keybind.value,
                list = item.Keybind.cfg.list == true,
                sync = item.Keybind.sync == true
            }
        else
            result.keybind = nil
        end

        return result
    elseif item.type == "slider" then
        return { type = "slider", value = item.value }
    elseif item.type == "dropdown" then
        return { type = "dropdown", value = item.value }
    elseif item.type == "textbox" then
        return { type = "textbox", value = item.value }
	elseif item.type == "keybind" then
		return {type = "keybind", key = item.key and tostring(item.key) or nil, mode = item.mode, state = item.value}
    elseif item.type == "colorpicker" then
        return {
            type = "colorpicker",
            value = {
                r = math.floor(item.value.R * 255),
                g = math.floor(item.value.G * 255),
                b = math.floor(item.value.B * 255)
            },
            alpha = item.Alpha or 0,
            rainbow = item.rainbow == true
        }
    end
end

function ConfigManager:Save(name)
    local data = {}

    for flag, item in pairs(self.Items) do
        data[flag] = self:SerializeValue(item)
    end

    return data
end

function ConfigManager:Load(data)
	for flag, saved in pairs(data) do
		local item = self.Items[flag]

		if item and saved and item.type == saved.type then

			if saved.type == "colorpicker" then
				if saved.value and saved.value.r and saved.value.g and saved.value.b then
					local loadedColor = Color3.fromRGB(saved.value.r, saved.value.g, saved.value.b)
					local loadedAlpha = saved.alpha or 0

					item:set(loadedColor, loadedAlpha)

					if item.setrainbow then
						item:setrainbow(saved.rainbow == true)
					end
				end

			elseif saved.type == "keybind" then
				if item.setbind and saved.key then
					item:setbind(saved.key)
				end

				if item.setmode and saved.mode then
					item:setmode(saved.mode)
				end

				if item.set and type(saved.state) == "boolean" then
					item:set(saved.state)
				end

        elseif saved.type == "toggle" then
            if saved.keybind and item.keybind and not item.Keybind then
                item:keybind({
                    flag = saved.keybind.flag,
                    default = saved.keybind.default,
                    mode = saved.keybind.mode,
                    state = saved.keybind.state,
                    list = saved.keybind.list,
                    sync = saved.keybind.sync
                })
            end

            if item.set and type(saved.value) == "boolean" then
                item:set(saved.value)
            end

            if saved.keybind and item.Keybind then
                if item.Keybind.setbind and saved.keybind.default then
                    item.Keybind:setbind(saved.keybind.default)
                end

                if item.Keybind.setmode and saved.keybind.mode then
                    item.Keybind:setmode(saved.keybind.mode)
                end

                if item.Keybind.set and type(saved.keybind.state) == "boolean" then
                    item.Keybind:set(saved.keybind.state, true)
                end

                if item.Keybind.cfg then
                    item.Keybind.cfg.list = saved.keybind.list == true
                end
            end

			elseif saved.type == "slider" then
				if item.set and type(saved.value) == "number" then
					item:set(saved.value)
				end

			elseif saved.type == "textbox" then
				if item.set and type(saved.value) == "string" then
					item:set(saved.value)
				end

			elseif saved.type == "dropdown" then
				if item.set then
					item:set(saved.value)
				end
			end

		end
	end
end

function ConfigManager:EnsureFolder()
    if not makefolder then
        return false, "makefolder is not supported by your executor"
    end

    if not isfolder(self.Folder) then
        makefolder(self.Folder)
    end

    return true
end

function ConfigManager:GetPath(name)
    return string.format("%s/%s.json", self.Folder, name)
end

function ConfigManager:RefreshConfigList()
    local ok, err = self:EnsureFolder()
    if not ok then
        warn(err)
        return {}
    end

    if not listfiles then
        warn("listfiles is not supported by your executor")
        return {}
    end

    local files = listfiles(self.Folder)
    local configs = {}

    for _, file in ipairs(files) do
        local name = file:match("([^/\\]+)%.json$")
        if name then
            table.insert(configs, name)
        end
    end

    table.sort(configs)
    return configs
end

function ConfigManager:CreateConfig(name)
    local ok, err = self:EnsureFolder()
    if not ok then
        return false, err
    end

    if not name or name == "" then
        return false, "No config name provided"
    end

    local path = self:GetPath(name)

    if isfile and isfile(path) then
        return false, "Config already exists"
    end

    if not writefile then
        return false, "writefile is not supported by your executor"
    end

    writefile(path, HttpService:JSONEncode({}))
    return true
end

function ConfigManager:SaveConfig(name)
    local ok, err = self:EnsureFolder()
    if not ok then
        return false, err
    end

    if not name or name == "" then
        return false, "No config name provided"
    end

    if not writefile then
        return false, "writefile is not supported by your executor"
    end

    local path = self:GetPath(name)
    local data = self:Save()

    writefile(path, HttpService:JSONEncode(data))
    return true
end

function ConfigManager:LoadConfig(name)
    if not name or name == "" then
        return false, "No config name provided"
    end

    local path = self:GetPath(name)

    if not readfile or not isfile then
        return false, "readfile/isfile is not supported by your executor"
    end

    if not isfile(path) then
        return false, "Config does not exist"
    end

    local raw = readfile(path)
    local decoded = HttpService:JSONDecode(raw)

    self:Load(decoded)
    return true
end

function ConfigManager:DeleteConfig(name)
    if not name or name == "" then
        return false, "No config name provided"
    end

    local path = self:GetPath(name)

    if not delfile or not isfile then
        return false, "delfile/isfile is not supported by your executor"
    end

    if not isfile(path) then
        return false, "Config does not exist"
    end

    delfile(path)
    return true
end

ConfigManager.AutoloadFile = ConfigManager.Folder .. "/autoload.txt"

function ConfigManager:GetAutoloadPath()
    return self.AutoloadFile
end

function ConfigManager:SetAutoload(name)
    local ok, err = self:EnsureFolder()
    if not ok then
        return false, err
    end

    if not name or name == "" then
        return false, "No config name provided"
    end

    if not writefile then
        return false, "writefile is not supported by your executor"
    end

    writefile(self:GetAutoloadPath(), tostring(name))
    return true
end

function ConfigManager:GetAutoload()
    local ok, err = self:EnsureFolder()
    if not ok then
        return nil, err
    end

    if not readfile or not isfile then
        return nil, "readfile/isfile is not supported by your executor"
    end

    local path = self:GetAutoloadPath()
    if not isfile(path) then
        return nil
    end

    local name = readfile(path)
    if not name or name == "" then
        return nil
    end

    return name
end

return ConfigManager
