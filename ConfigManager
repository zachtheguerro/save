ConfigConfig:button({
    name = "Create Config",
    callback = function()
        local name = library.flags["cfgname"]

        local success, message = ConfigManager:CreateConfig(name)
        if success then
            cfglist:setoptions(ConfigManager:RefreshConfigList())
            cfglist:set(name)
            library:Notify({
                text = "Created config",
                time = 3,
                highlights = {tostring(name)}
            })

            local success2, message2 = ConfigManager:SaveConfig(name)
            if success2 then
                cfglist:setoptions(ConfigManager:RefreshConfigList())
                cfglist:set(name)
                library:Notify({
                    text = "Saved config",
                    time = 3,
                    highlights = {tostring(name)}
                })
            else
                library:Notify({
                    text = "Save failed",
                    time = 3,
                    highlights = {tostring(message2)}
                })
            end
        else
            library:Notify({
                text = "Create failed",
                time = 3,
                highlights = {tostring(message)}
            })
        end
    end
})

