			for _, child in ipairs(sideFrame:GetChildren()) do
				if child ~= ignore and (child:IsA("ScrollingFrame") or child:IsA("Frame")) then
					used = used + child.AbsoluteSize.Y
					sectionCount = sectionCount + 1
				end
			end

			local layout = sideFrame:FindFirstChildOfClass("UIListLayout")
			local paddingOffset = layout and layout.Padding.Offset or 0

			local existingGaps = math.max(0, sectionCount - 1) * paddingOffset
			local newGap = sectionCount > 0 and paddingOffset or 0

			local topPadding = 0
			local sidePaddingObj = sideFrame:FindFirstChildOfClass("UIPadding")
			if sidePaddingObj then
				topPadding = sidePaddingObj.PaddingTop.Offset
