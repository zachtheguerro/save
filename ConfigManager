			end
		end

		if Frame.Visible then
			updateColorpickerPosition()
		end
	end)

	colorpicker:set(Color3.fromHSV(colorpicker.Hue, colorpicker.Sat, colorpicker.Vib))

	library.items[flag] = colorpicker
	ConfigManager:Register(flag, colorpicker)
	colorpicker.value = Color3.fromHSV(colorpicker.Hue, colorpicker.Sat, colorpicker.Vib)

	Pointer.Position = UDim2.new(0, colorpicker.Sat * LeftDrag.AbsoluteSize.X, 0, (1 - colorpicker.Vib) * LeftDrag.AbsoluteSize.Y)
	Line.Position = UDim2.new(0.5, 0, 0, math.clamp(colorpicker.Hue * RightDrag.AbsoluteSize.Y, 0, RightDrag.AbsoluteSize.Y - 2))

