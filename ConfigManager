		rainbow = state and true or false
		colorpicker.rainbow = rainbow
		RainbowToggle:SetAttribute("Selected", rainbow)

		if rainbowConnection then
			rainbowConnection:Disconnect()
			rainbowConnection = nil
		end

		if rainbow then
			RainbowToggle.Text = "Rainbow: On"
			RainbowToggle.TextColor3 = library.accent
			RainbowToggle:SetAttribute("AccentProps", "TextColor3")

			rainbowConnection = library:connect(RunService.RenderStepped, function()
