					text = tostring(text or "")
					
					local font = label.Font
					local textSize = label.TextSize
					if not font or font == Enum.Font.Unknown then
						font = Enum.Font.SourceSans
					end

					local bounds = TextService:GetTextSize(text, textSize, font, Vector2.new(math.huge, textSize))
					if bounds.X <= Box.AbsoluteSize.X * 0.9 then
						label.Text = text
						return
					end

					local trimmed = text
					while #trimmed > 0 do
						trimmed = trimmed:sub(1, #trimmed - 1)
						local test = trimmed .. "..."
						local testBounds = TextService:GetTextSize(test, textSize, font, Vector2.new(math.huge, textSize))
						if testBounds.X <= Box.AbsoluteSize.X * 0.9 then
							label.Text = test
