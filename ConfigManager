function library:Unload()
	for k, _ in pairs(self.flags) do
		self.flags[k] = false
	end

	for i, connection in ipairs(self.connections) do
		if connection and connection.Disconnect then
			connection:Disconnect()
		end
	end
	table.clear(self.connections)

	for obj, _ in pairs(self.objects) do
		if obj and obj.Destroy then
			obj:Destroy()
		end
	end
	table.clear(self.objects)

	table.clear(self.tabs)

	if self.frame and self.frame.Destroy then
		self.frame:Destroy()
		self.frame = nil
	end

	getgenv().library = nil
end

function library:makedraggable(Instance, Cutoff)
	Instance.Active = true

	Instance.InputBegan:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 then
			local ObjPos = Vector2.new(
				Mouse.X - Instance.AbsolutePosition.X,
				Mouse.Y - Instance.AbsolutePosition.Y
			)

			if ObjPos.Y > (Cutoff or 40) then
				return
			end

			while InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
				local newX = math.floor(Mouse.X - ObjPos.X + (Instance.Size.X.Offset * Instance.AnchorPoint.X) + 0.5)
				local newY = math.floor(Mouse.Y - ObjPos.Y + (Instance.Size.Y.Offset * Instance.AnchorPoint.Y) + 0.5)

				Instance.Position = UDim2.new(0, newX, 0, newY)

				RunService.RenderStepped:Wait()
			end
		end
	end)
end

function library:table(tbl, usemt)
	tbl = tbl or {}

	local oldtbl = table.clone(tbl)
	table.clear(tbl)

	for i, v in next, oldtbl do
		if type(i) == "string" then
			tbl[i:lower()] = v
		else
			tbl[i] = v
		end
	end

	if usemt == true then
		setmetatable(tbl, {
			__index = function(t, k)
				return rawget(t, k:lower()) or rawget(t, k)
			end,

			__newindex = function(t, k, v)
				if type(k) == "string" then
					rawset(t, k:lower(), v)
				else
					rawset(t, k, v)
				end
			end
		})
	end

	return tbl
end;

function library:connect(signal, callback)
	local connection = signal:Connect(callback)
	table.insert(library.connections, connection)

	return connection
end;

function library:disconnect(connection)
	local index = table.find(library.connections, connection)
	connection:Disconnect()

	if index then
		table.remove(library.connections, index)
	end
end;

function library:gettextbounds(text, font, size, resolution)
	text = tostring(text or "")
	size = size or 13
	resolution = resolution or Vector2.new(1920, 1080)

	if typeof(font) == "Font" then
		local params = Instance.new("GetTextBoundsParams")
		params.Text = text
		params.Size = size
		params.Font = font
		params.Width = resolution.X

		local bounds = TextService:GetTextBoundsAsync(params)
		return bounds.X, bounds.Y
	else
		local bounds = TextService:GetTextSize(text, size, font or Enum.Font.SourceSans, resolution)
		return bounds.X, bounds.Y
	end
end

function library:round(number, float)
	number = tonumber(number) or 0
	float = tonumber(float) or 1
	return float * math.floor(number / float)
end

local unnamedflags = 0;
function library:nextflag()
	unnamedflags = unnamedflags + 1
	return string.format("%.14g", unnamedflags)
end;

function library:mouseffects(item, stroke)
	if not item or not stroke then
		return
	end

	stroke:SetAttribute("IsAccent", "Color")
	stroke:SetAttribute("Selected", false)
	stroke:SetAttribute("Pressed", false)

	item.MouseEnter:Connect(function()
		stroke:SetAttribute("Selected", true)

		if not stroke:GetAttribute("Pressed") then
			stroke.Color = library.accent
		end
	end)

	item.MouseLeave:Connect(function()
		stroke:SetAttribute("Selected", false)
		stroke:SetAttribute("Pressed", false)
		stroke.Color = library.stroke
	end)

	if item:IsA("TextBox") or item:IsA("Frame") or item:IsA("ImageLabel") then
		return
	end

	item.MouseButton1Down:Connect(function()
		stroke:SetAttribute("Pressed", true)
		stroke.Color = library.stroke
	end)

	item.MouseButton1Up:Connect(function()
		stroke:SetAttribute("Pressed", false)

		if stroke:GetAttribute("Selected") then
			stroke.Color = library.accent
		else
			stroke.Color = library.stroke
		end
	end)
end

