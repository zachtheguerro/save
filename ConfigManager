				colorpicker.Hue = hue
				colorpicker.Sat = 1
				colorpicker.Vib = 1
				Line.Position = UDim2.new(0.5,0,0,hue * RightDrag.AbsoluteSize.Y)
				Pointer.Position = UDim2.new(1,0,0,0)
				local alphaX = (1 - colorpicker.Alpha) * (BottomDrag.AbsoluteSize.X - 1)
				Line2.Position = UDim2.new(0, alphaX, 0.5, 0)

				colorpicker:set(Color3.fromHSV(colorpicker.Hue, colorpicker.Sat, colorpicker.Vib), colorpicker.Alpha)
			end)
		else
			RainbowToggle.Text = "Rainbow: Off"
			RainbowToggle.TextColor3 = library.textcolor;
			RainbowToggle:SetAttribute("AccentProps", nil)
			RainbowToggle:SetAttribute("Selected", false)
		end
	end

