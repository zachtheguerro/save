			ZIndex = 98;
		})

		local BarTop = library:Create("Frame", {
			Parent = Notification;
			BackgroundColor3 = library.accent;
			BorderSizePixel = 0;
			Position = UDim2.new(0, 0, 0, 0);
			Size = UDim2.new(1, 0, 0, 2);
			ZIndex = 100;
		})

		local BarBottom = library:Create("Frame", {
			Parent = Notification;
			BackgroundColor3 = Color3.fromRGB(33, 18, 48);
			BackgroundTransparency = 0.5;
			BorderSizePixel = 0;
			Position = UDim2.new(0, 0, 0, 1);
			Size = UDim2.new(1, 0, 0, 1);
			ZIndex = 100;
		})

		local TimeBar = library:Create("Frame", {
			Parent = Notification;
			BackgroundColor3 = library.accent;
			BorderSizePixel = 0;
			AnchorPoint = Vector2.new(1, 1);
			Position = UDim2.new(1, 0, 1, 0);
			Size = UDim2.new(1, 0, 0, 1);
			ZIndex = 100;
		})

		local MainText = library:Create("TextLabel", {
			Parent = Notification;
			BackgroundTransparency = 1;
			Text = tostring(text);
			FontFace = library.font;
			TextSize = 12;
			TextColor3 = library.textcolor;
			TextXAlignment = Enum.TextXAlignment.Left;
			TextYAlignment = Enum.TextYAlignment.Center;
			Position = UDim2.new(0, 8, 0, topPad - 1);
			Size = UDim2.new(1, -16, 0, lineHeight);
			ZIndex = 100;
		})

		for i, highlightText in ipairs(highlights) do
			library:Create("TextLabel", {
				Parent = Notification;
				BackgroundTransparency = 1;
				Text = tostring(highlightText);
				FontFace = library.font;
				TextSize = 12;
				TextColor3 = library.accent;
				TextXAlignment = Enum.TextXAlignment.Left;
				TextYAlignment = Enum.TextYAlignment.Center;
				Position = UDim2.new(0, 8, 0, topPad - 1 + (i * lineHeight));
				Size = UDim2.new(1, -16, 0, lineHeight);
				ZIndex = 100;
			})
		end

		notification.Frame = Notification
		notification.TimeBar = TimeBar
		notification.Height = notifHeight
		notification.TargetY = 0
		notification.Removing = false
		notification.MoveTween = nil
		notification.TimeTween = nil

		table.insert(self.notifications, 1, notification)

		self:updatenotis()

		Notification.Position = UDim2.new(1, notifWidth + 20, 0, notification.TargetY)

		notification.MoveTween = TweenService:Create(
			Notification,
			TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
			{
				Position = UDim2.new(1, -10, 0, notification.TargetY)
			}
		)
		notification.MoveTween:Play()

		notification.TimeTween = TweenService:Create(
			TimeBar,
			TweenInfo.new(lifetime, Enum.EasingStyle.Linear),
			{
				Size = UDim2.new(0, 0, 0, 1)
			}
		)
		notification.TimeTween:Play()

		task.spawn(function()
			task.wait(lifetime)
			library:removenoti(notification)
		end)

		return notification
	end

    return window
end

