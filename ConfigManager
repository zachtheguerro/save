function library:Create(class, prop)
    local object = Instance.new(class)
    prop = typeof(prop) == "table" and prop or {}

    local accentProps = {}
	local strokeProps = {}
	local strokeProps2 = {}
	local buttonProps = {}
	local contentProps = {}
	local backgroundProps = {}
	local sectionProps = {}
	local textProps = {}
	local miscProps = {}

    for i, v in next, prop do
        if v == library.accent then
            table.insert(accentProps, i)
        end

		if v == library.stroke then
			table.insert(strokeProps, i)
		end
		if v == library.stroke2 then
			table.insert(strokeProps2, i)
		end

		if v == library.buttoncolor then
			table.insert(buttonProps, i)
		end

		if v == library.contentcolor then
			table.insert(contentProps, i)
		end

		if v == library.backgroundcolor then
			table.insert(backgroundProps, i)
		end

		if v == library.sectioncolor then
			table.insert(sectionProps, i)
		end

		if v == library.textcolor then
			table.insert(textProps, i)
		end

		if v == library.misccolor then
			table.insert(miscProps, i)
		end

        object[i] = v
    end

    if #accentProps > 0 then
        object:SetAttribute("AccentProps", table.concat(accentProps, ","))
    end

	if #strokeProps > 0 then
        object:SetAttribute("StrokeProps", table.concat(strokeProps, ","))
    end

	if #strokeProps2 > 0 then
        object:SetAttribute("StrokeProps2", table.concat(strokeProps2, ","))
    end

	if #buttonProps > 0 then
        object:SetAttribute("Buttons", table.concat(buttonProps, ","))
    end

	if #contentProps > 0 then
        object:SetAttribute("ContentProps", table.concat(contentProps, ","))
    end

	if #backgroundProps > 0 then
        object:SetAttribute("BackgroundProps", table.concat(backgroundProps, ","))
    end

	if #sectionProps > 0 then
        object:SetAttribute("SectionProps", table.concat(sectionProps, ","))
    end

	if #textProps > 0 then
        object:SetAttribute("TextProps", table.concat(textProps, ","))
    end

	if #miscProps > 0 then
        object:SetAttribute("MiscProps", table.concat(miscProps, ","))
    end

    library.objects[object] = object
    return object
end

