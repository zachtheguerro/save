	function library:updatenotis(skipTweenFor)
		local spacing = 8
		local currentY = 0

		for i, notif in ipairs(self.notifications) do
			if notif and notif.Frame and notif.Frame.Parent then
				notif.TargetY = currentY

				if notif.MoveTween then
					notif.MoveTween:Cancel()
					notif.MoveTween = nil
				end

				local goal = UDim2.new(1, -10, 0, currentY)

				if notif ~= skipTweenFor then
					notif.MoveTween = TweenService:Create(
						notif.Frame,
						TweenInfo.new(0.1, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
						{Position = goal}
					)
					notif.MoveTween:Play()
				else
					notif.Frame.Position = goal
				end

				currentY = currentY + notif.Height + spacing
			end
		end
	end

	function library:removenoti(notification)
		if not notification or notification.Removing then
			return
		end

		notification.Removing = true

		local frame = notification.Frame
		if not frame or not frame.Parent then
			local index = table.find(self.notifications, notification)
			if index then
				table.remove(self.notifications, index)
				self:updatenotis()
			end
			return
		end

		if notification.MoveTween then
			notification.MoveTween:Cancel()
			notification.MoveTween = nil
		end

		if notification.TimeTween then
			notification.TimeTween:Cancel()
			notification.TimeTween = nil
		end

		local removeTween = TweenService:Create(
			frame,
			TweenInfo.new(0.2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
			{
				Position = UDim2.new(1, frame.AbsoluteSize.X + 20, 0, notification.TargetY)
			}
		)

		removeTween:Play()
		removeTween.Completed:Once(function()
			local index = table.find(self.notifications, notification)
			if index then
				table.remove(self.notifications, index)
			end

			if frame then
				frame:Destroy()
			end

			self:updatenotis()
		end)
	end

	function library:Notify(cfg)
		local notification = {}

		local text = cfg.text or cfg.Text or "Notification"
		local lifetime = cfg.time or cfg.Time or 5
		local highlights = cfg.highlights or cfg.Highlights or {}

		if type(highlights) ~= "table" then
			highlights = {}
		end

		local padding = 10
		local lineHeight = 16
		local topPad = 4
		local bottomPad = 8

		local totalLines = 1 + #highlights
		local notifHeight = topPad + (totalLines * lineHeight) + 2

		local longestWidth = library:gettextbounds(tostring(text), library.font, 12)

		for _, highlightText in ipairs(highlights) do
			local highlightWidth = library:gettextbounds(tostring(highlightText), library.font, 12)
			if highlightWidth > longestWidth then
				longestWidth = highlightWidth
			end
		end

		local notifWidth = longestWidth + 15

